{
  "expo": {
    "name": "TrailNest",
    "slug": "trailnest-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "trailnest",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2f5d3a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trailnest.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2f5d3a"
      },
      "package": "com.trailnest.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
